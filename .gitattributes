# Auto-detect text files and normalize line endings to LF
* text=auto

# Ensure shell scripts use LF
*.sh eol=lf
*.bash eol=lf

# Ensure Windows scripts use CRLF
*.bat eol=crlf
*.cmd eol=crlf
*.ps1 eol=crlf

# Document files
*.md text eol=lf
*.mdx text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Code files
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.py text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary
